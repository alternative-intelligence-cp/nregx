use "nregx.npk".*;
use "regex_types.npk".*;
use "util/mem_primitives.npk".*;

extern "nitpick_libc_sys" {
    func:npk_sys_print = void(int64:str, int32:len);
    func:npk_sys_exit = void(int32:code);
}

func:print_str = int32(int64:str, int32:len) {
    npk_sys_print(str, len);
    pass 0i32;
};

pub func:main = int32() {
    drop nregx_init();
    
    // Test 1: [0-9]
    // "a[0-9]b" is 7 bytes
    int64:pat1 = npk_core_alloc(7i64);
    drop npk_mem_write_byte(pat1, 0i64, 97i64); // 'a'
    drop npk_mem_write_byte(pat1, 1i64, 91i64); // '['
    drop npk_mem_write_byte(pat1, 2i64, 48i64); // '0'
    drop npk_mem_write_byte(pat1, 3i64, 45i64); // '-'
    drop npk_mem_write_byte(pat1, 4i64, 57i64); // '9'
    drop npk_mem_write_byte(pat1, 5i64, 93i64); // ']'
    drop npk_mem_write_byte(pat1, 6i64, 98i64); // 'b'
    
    int64:txt1 = npk_core_alloc(3i64);
    drop npk_mem_write_byte(txt1, 0i64, 97i64); // 'a'
    drop npk_mem_write_byte(txt1, 1i64, 53i64); // '5'
    drop npk_mem_write_byte(txt1, 2i64, 98i64); // 'b'
    
    MatchResult:res1 = raw nregx_match(pat1, 7i64, txt1, 3i64);
    if (res1.matched == 1i32) {
        // print
    }
    
    // Test 2: ^a.$
    int64:pat2 = npk_core_alloc(4i64);
    drop npk_mem_write_byte(pat2, 0i64, 94i64); // '^'
    drop npk_mem_write_byte(pat2, 1i64, 97i64); // 'a'
    drop npk_mem_write_byte(pat2, 2i64, 46i64); // '.'
    drop npk_mem_write_byte(pat2, 3i64, 36i64); // '$'
    
    int64:txt2 = npk_core_alloc(2i64);
    drop npk_mem_write_byte(txt2, 0i64, 97i64); // 'a'
    drop npk_mem_write_byte(txt2, 1i64, 98i64); // 'b'
    
    MatchResult:res2 = raw nregx_match(pat2, 4i64, txt2, 2i64);
    if (res2.matched == 1i32) {
        // print
    }
    
    // Test 3: \d+
    int64:pat3 = npk_core_alloc(3i64);
    drop npk_mem_write_byte(pat3, 0i64, 92i64); // '\'
    drop npk_mem_write_byte(pat3, 1i64, 100i64); // 'd'
    drop npk_mem_write_byte(pat3, 2i64, 43i64); // '+'
    
    int64:txt3 = npk_core_alloc(3i64);
    drop npk_mem_write_byte(txt3, 0i64, 49i64); // '1'
    drop npk_mem_write_byte(txt3, 1i64, 50i64); // '2'
    drop npk_mem_write_byte(txt3, 2i64, 51i64); // '3'
    
    MatchResult:res3 = raw nregx_match(pat3, 3i64, txt3, 3i64);
    if (res3.matched == 1i32) {
        // print
    }
    
    // Test 4: match boundary
    int64:pat4 = npk_core_alloc(3i64);
    drop npk_mem_write_byte(pat4, 0i64, 98i64); // 'b'
    drop npk_mem_write_byte(pat4, 1i64, 43i64); // '+'
    drop npk_mem_write_byte(pat4, 2i64, 99i64); // 'c'
    
    int64:txt4 = npk_core_alloc(6i64);
    drop npk_mem_write_byte(txt4, 0i64, 97i64); // 'a'
    drop npk_mem_write_byte(txt4, 1i64, 97i64); // 'a'
    drop npk_mem_write_byte(txt4, 2i64, 98i64); // 'b'
    drop npk_mem_write_byte(txt4, 3i64, 98i64); // 'b'
    drop npk_mem_write_byte(txt4, 4i64, 98i64); // 'b'
    drop npk_mem_write_byte(txt4, 5i64, 99i64); // 'c'
    MatchResult:res4 = raw nregx_match(pat4, 3i64, txt4, 6i64);
    if (res4.matched == 1i32) {
        if ((res4.start_idx == 2i32) && (res4.end_idx == 6i32)) {
            // print
        } else {
            // print
        }
    }

    exit 0i32;
};

pub func:failsafe = int32(tbb32:err) {
    drop err;
    exit 1i32;
};
