use "nregx.npk".*;
use "regex_types.npk".*;
use "util/mem_primitives.npk".*;

extern "nitpick_libc_sys" {
    func:npk_sys_print = void(int64:str, int32:len);
    func:npk_sys_exit = void(int32:code);
}

pub func:main = int32() {
    drop nregx_init();

    // Pattern: 'a' '❤' 'b' (❤ is U+2764, encoded as E2 9D A4)
    int64:pat1 = npk_core_alloc(5i64);
    drop npk_mem_write_byte(pat1, 0i64, 97i64); // 'a'
    drop npk_mem_write_byte(pat1, 1i64, 226i64); // 0xE2
    drop npk_mem_write_byte(pat1, 2i64, 157i64); // 0x9D
    drop npk_mem_write_byte(pat1, 3i64, 164i64); // 0xA4
    drop npk_mem_write_byte(pat1, 4i64, 98i64); // 'b'

    // Text: 'a' '❤' 'b'
    int64:txt1 = npk_core_alloc(5i64);
    drop npk_mem_write_byte(txt1, 0i64, 97i64); // 'a'
    drop npk_mem_write_byte(txt1, 1i64, 226i64); // 0xE2
    drop npk_mem_write_byte(txt1, 2i64, 157i64); // 0x9D
    drop npk_mem_write_byte(txt1, 3i64, 164i64); // 0xA4
    drop npk_mem_write_byte(txt1, 4i64, 98i64); // 'b'

    MatchResult:res1 = raw nregx_match(pat1, 5i64, txt1, 5i64);
    
    // We expect 101 for match, 100 for no match
    if (res1.end_idx != 5i32) {
        exit 201i32;
    }
    exit 100i32 + res1.matched;
};

pub func:failsafe = int32(tbb32:err) { drop err;
    exit 242i32;
};
