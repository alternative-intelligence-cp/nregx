use "../src/nregx.npk".*;

func:assert_match = int32(int64:pattern, int64:plen, int64:text, int64:tlen, int32:expect) {
    MatchResult:res_struct = raw nregx_match(pattern, plen, text, tlen);
    int32:res = res_struct.matched;
    if (res != expect) {
        pass 1i32;
    }
    pass 0i32;
};

pub func:main = int32() {
    drop(nregx_init());

    // Pattern: a(b|c)+d?
    string:pattern_str = "a(b|c)+d?";
    int64:pattern = string_to_cstr(pattern_str);
    int64:plen = 9i64;

    int32:err = 0i32;
    err = err + raw assert_match(pattern, plen, string_to_cstr("ab"), 2i64, 1i32);
    err = err + raw assert_match(pattern, plen, string_to_cstr("ac"), 2i64, 1i32);
    err = err + raw assert_match(pattern, plen, string_to_cstr("abc"), 3i64, 1i32);
    err = err + raw assert_match(pattern, plen, string_to_cstr("abcd"), 4i64, 1i32);
    err = err + raw assert_match(pattern, plen, string_to_cstr("ad"), 2i64, 0i32);
    err = err + raw assert_match(pattern, plen, string_to_cstr("a"), 1i64, 0i32);
    err = err + raw assert_match(pattern, plen, string_to_cstr("acbccd"), 6i64, 1i32);

    if (err > 0i32) {
        exit 1i32;
    }
    exit 0i32;
};

pub func:failsafe = int32(tbb32:err) {
    drop err;
    exit 1i32;
};
