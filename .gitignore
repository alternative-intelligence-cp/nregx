# ============================================================================
# NREGX — Nitpick Regex Engine in Nitpick — .gitignore
# ============================================================================

# --------------------------------------------------------------------------
# Build output
# --------------------------------------------------------------------------
build/
out/
bin/
obj/
dist/

# --------------------------------------------------------------------------
# Nitpick compiler output
# --------------------------------------------------------------------------
*.npko
*.ll
*.bc
*.s
*.ir

# --------------------------------------------------------------------------
# Native object / library / binary artifacts
# --------------------------------------------------------------------------
*.o
*.so
*.so.*
*.a
*.dylib
*.dll
*.exe
*.out

# --------------------------------------------------------------------------
# LLVM / Clang artifacts
# --------------------------------------------------------------------------
*.pch
*.gch
*.dSYM/
*.dwo
*.dwp

# --------------------------------------------------------------------------
# npkbld build system state
# --------------------------------------------------------------------------
.npkbld/
.build_state/
.nitpick_make/
.aria_make/

# --------------------------------------------------------------------------
# Debug & profiling artifacts
# --------------------------------------------------------------------------
*.debug
/core
/core.*
vgcore.*
perf.data
perf.data.old
*.flamegraph

# --------------------------------------------------------------------------
# Database data files (never commit live data)
# --------------------------------------------------------------------------
*.db
*.wal
*.sst
*.log
data/
wal/
sstables/
snapshots/
index/

# --------------------------------------------------------------------------
# Test artifacts & coverage
# --------------------------------------------------------------------------
test_output/
*.test_result
coverage/
*.gcno
*.gcda
*.gcov
*.profraw
*.profdata

# --------------------------------------------------------------------------
# Benchmark results (track separately if needed)
# --------------------------------------------------------------------------
bench_output/
*.bench

# --------------------------------------------------------------------------
# Documentation build
# --------------------------------------------------------------------------
docs/_build/
docs/html/
docs/latex/

# --------------------------------------------------------------------------
# IDE and editor files
# --------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace
.vim/
tags
TAGS
*.kate-swp
.clangd/

# --------------------------------------------------------------------------
# OS-generated files
# --------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --------------------------------------------------------------------------
# Temporary / scratch files
# --------------------------------------------------------------------------
tmp/
temp/
scratch/
*.tmp
*.bak
*.orig
*.rej

# --------------------------------------------------------------------------
# CMake (if used for C shim components)
# --------------------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile.cmake
compile_commands.json
install_manifest.txt
CTestTestfile.cmake

# --------------------------------------------------------------------------
# Packaging
# --------------------------------------------------------------------------
*.deb
*.rpm
*.AppImage
*.snap
*.tar.gz
*.tar.xz
*.tar.bz2
*.zip

# --------------------------------------------------------------------------
# Fuzz Testing
# --------------------------------------------------------------------------
fuzz_payload.json
fuzz_out.log
